# App
NODE_ENV=development
HTTP_PORT=3000
LOG_LEVEL=debug

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nestjs-kafka-avro
KAFKA_GROUP_ID=nestjs-kafka-avro-group
# Optional SASL (leave blank to disable)
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL=false

# Schema Registry
SCHEMA_REGISTRY_URL=http://localhost:8081
SCHEMA_REGISTRY_USER=
SCHEMA_REGISTRY_PASS=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nestjs-kafka-avro
METRICS_PORT=9464

# Consumer lag poll interval (ms)
CONSUMER_LAG_POLL_MS=15000
