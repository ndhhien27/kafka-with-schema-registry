# App
NODE_ENV=development
HTTP_PORT=3000
LOG_LEVEL=debug

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nestjs-kafka-avro
KAFKA_GROUP_ID=nestjs-kafka-avro-group
KAFKA_SSL=false
# SASL is dormant — fields kept here for future SASL_SSL re-enable, not wired today
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Topic naming: `${ORG}-${APP}-${ENV}-${FEATURE}-${TYPE}` per BTH guideline
KAFKA_TOPIC_ORG=one
KAFKA_TOPIC_APP=bth
KAFKA_TOPIC_ENV=dev

# Schema Registry
SCHEMA_REGISTRY_URL=http://localhost:8081
SCHEMA_REGISTRY_USER=
SCHEMA_REGISTRY_PASS=
# FULL is the BTH guideline default (only optional add/delete allowed)
SCHEMA_COMPATIBILITY=FULL

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nestjs-kafka-avro
METRICS_PORT=9464

# Consumer lag poll interval (ms)
CONSUMER_LAG_POLL_MS=15000

# Orkes Conductor (cloud trial: https://developer.orkescloud.com)
ORKES_ENABLED=false
ORKES_SERVER_URL=
ORKES_KEY=
ORKES_SECRET=
ORKES_AUTO_REGISTER=false
